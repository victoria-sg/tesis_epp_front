+// ─── Esquema de validación del formulario de usuarios ────────────────────────
+// Se construye como función porque la contraseña (y su confirmación) solo
+// son obligatorias al crear un usuario, no al editarlo. Antes esto se
+// intentaba resolver con `.when("isEdit", ...)`, pero "isEdit" nunca
+// llegaba a existir en los valores del formulario, por lo que la
+// contraseña nunca se exigía realmente al crear un usuario.
+export const buildUsuarioSchema = (isEditing: boolean) =>
+  Yup.object({
+    nombre: Yup.string()
+      .required("El nombre es obligatorio")
+      .max(100, "Máximo 100 caracteres"),
+    apelido: Yup.string()
+      .required("El apellido es obligatorio")
+      .max(100, "Máximo 100 caracteres"),
+    correo: Yup.string()
+      .email("Correo no válido")
+      .required("El correo es obligatorio"),
+    id_rol: Yup.number()
+      .typeError("Selecciona un rol")
+      .required("El rol es obligatorio"),
+    contrasena: isEditing
+      ? Yup.string().notRequired()
+      : passwordSeguraSchema,
+    confirmar_contrasena: isEditing
+      ? Yup.string().notRequired()
+      : confirmarPasswordSchema("contrasena"),
+  });
 
-export type UsuarioFormValues = Yup.InferType<typeof usuarioSchema>;
+export interface UsuarioFormValues {
+  nombre: string;
+  apelido: string;
+  correo: string;
+  id_rol: number;
+  contrasena?: string;
+  confirmar_contrasena?: string;
+  [key: string]: unknown;
+}
